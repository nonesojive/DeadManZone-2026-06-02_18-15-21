/[Aa]ssets/LowPolySoldiers_demo.meta
/[Aa]ssets/Military WW2 Music Pack/
/[Aa]ssets/Military WW2 Music Pack.meta
/[Aa]ssets/PostApocalypseGunsDemo/
/[Aa]ssets/PostApocalypseGunsDemo.meta
/[Aa]ssets/ProceduralToolkit/
/[Aa]ssets/ProceduralToolkit.meta
/[Aa]ssets/RTS_Modern_Combat_Vehicle_Pack_Free/
/[Aa]ssets/RTS_Modern_Combat_Vehicle_Pack_Free.meta
/[Aa]ssets/Sci-Fi Texture Pack 1/
/[Aa]ssets/Sci-Fi Texture Pack 1.meta
/[Aa]ssets/Sci_Fi_Character_08/
/[Aa]ssets/Sci_Fi_Character_08.meta
/[Aa]ssets/SimpleApocalypse/
/[Aa]ssets/SimpleApocalypse.meta
