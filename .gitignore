/[Aa]ssets/SimpleIcons.meta
/[Aa]ssets/SimpleItems/
/[Aa]ssets/SimpleItems.meta
/[Aa]ssets/SimpleMilitary/
/[Aa]ssets/SimpleMilitary.meta
/[Aa]ssets/SimpleProps/
/[Aa]ssets/SimpleProps.meta
/[Aa]ssets/Toon_RTS_demo/
/[Aa]ssets/Toon_RTS_demo.meta
/[Aa]ssets/Toon_Soldiers/
/[Aa]ssets/Toon_Soldiers.meta
/[Aa]ssets/UltimateIsometricToolkit/
/[Aa]ssets/UltimateIsometricToolkit.meta
/[Aa]ssets/WW2_German_soilders/
/[Aa]ssets/WW2_German_soilders.meta
/[Aa]ssets/_Creepy_Cat/
/[Aa]ssets/_Creepy_Cat.meta
/[Aa]ssets/room/
/[Aa]ssets/room.meta

# Claude Code — personal settings, not shared with the team
.claude/settings.local.json

# Unity MCP tool stubs + skill symlinks — regenerated locally by the MCP
# bridge and by `npx skills` (see skills-lock.json), not portable across machines
.claude/skills/

# Vendored skill sources fetched via `npx skills` from skills-lock.json
.agents/

# Meshy 3D->sprite pipeline: large regenerable intermediates (keep the .py scripts, ignore data)
# Exception: units/*/refs/ — reference images are the SOURCE of each model (unit-art spec 7.6), tracked.
/Tools/meshy/units/**
!/Tools/meshy/units/*/
!/Tools/meshy/units/*/refs/
!/Tools/meshy/units/*/refs/**
/Tools/meshy/output/
/Tools/meshy/glb/
/Tools/meshy/frames/
/Tools/meshy/backup/
/Tools/meshy/input/
/Tools/meshy/*.log
/Tools/meshy/*.txt
/tmp_combat_scale_watch/
/Tools/meshy/__pycache__/
